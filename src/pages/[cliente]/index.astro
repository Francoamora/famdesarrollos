---
import Layout from '../../layouts/Layout.astro';
import { ArrowLeft, Lock } from 'lucide-react';

// En Astro (Static Site Generation), necesitamos definir de antemano qué URLs existen.
export function getStaticPaths() {
  return [
    { params: { cliente: 'demo' } },
    { params: { cliente: 'tukiosco' } },
    { params: { cliente: 'munifinanzas' } },
    { params: { cliente: 'portal' } }
  ];
}

const { cliente } = Astro.params;
---

<Layout title={`Portal de ${cliente} | FAM Desarrollos`}>
  <main class="min-h-screen bg-[#030303] text-white flex flex-col items-center justify-center p-4">
    
    <div class="w-full max-w-2xl bg-white/[0.02] border border-white/10 rounded-3xl p-10 md:p-16 text-center animate-fade-in-up">

      <div class="flex justify-center mb-8">
        <div class="w-20 h-20 bg-white/5 rounded-2xl flex items-center justify-center border border-white/10">
          <Lock class="w-8 h-8 text-white" />
        </div>
      </div>

      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-white font-bold text-xs mb-6 uppercase tracking-widest">
        Entorno Privado
      </div>
      
      <h1 class="text-4xl md:text-5xl font-black mb-4 capitalize tracking-tight text-white">
        Portal: {cliente}
      </h1>
      
      <p class="text-gray-400 text-lg mb-10 leading-relaxed font-light">
        Esta es la plataforma privada de <span class="capitalize text-white font-medium">{cliente}</span>. Operando bajo la arquitectura y seguridad de FAM Desarrollos.
      </p>

      <a href="/" class="inline-flex items-center gap-2 text-white font-bold bg-white/10 hover:bg-white/20 border border-white/10 rounded-xl px-8 py-4 transition-all">
        <ArrowLeft size={20} /> Volver al Inicio
      </a>
    </div>

  </main>
</Layout>
