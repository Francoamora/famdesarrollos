---
import Layout from '../../layouts/Layout.astro';
import { Monitor, Briefcase, Rocket, Code, Database, LineChart, Cpu, Network, Zap, ArrowRight, Building, MessageCircle, Newspaper, Store, Wrench, Sparkles, ArrowUpRight } from 'lucide-react';
import TerminalAbout from '../../components/TerminalAbout.jsx';
import SolutionsCarousel from '../../components/SolutionsCarousel.jsx';
import ProcessSection from '../../components/ProcessSection.jsx';
import FaqSection from '../../components/FaqSection.jsx';
import ContactSection from '../../components/ContactSection.jsx';
---

<Layout title="FAM Desarrollos | Digital Innovation" lang="en">
	<main class="w-full flex flex-col items-center justify-center min-h-screen">
		<!-- Navigation (Minimal Terminal Style) -->
		<nav id="main-nav" class="w-full fixed top-0 z-50 bg-black/40 backdrop-blur-lg border-b border-white/5 transition-transform duration-300">
			<div class="max-w-6xl mx-auto px-4 md:px-6 py-3 md:py-4 flex justify-between items-center relative">
				
				<div class="w-20 hidden md:block"></div>

				<a href="#" class="absolute left-1/2 -translate-x-1/2 bg-black/80 border border-white/10 rounded-lg md:rounded-xl px-3 py-2 md:px-5 md:py-2.5 font-mono flex items-center gap-2 md:gap-3 group cursor-pointer overflow-hidden shadow-[0_0_20px_rgba(6,182,212,0.15)] hover:shadow-[0_0_30px_rgba(6,182,212,0.3)] hover:-translate-y-0.5 transition-all w-max max-w-[65vw]">
					<div class="absolute inset-0 bg-gradient-to-r from-cyan-500/10 to-blue-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
					<div class="text-gray-500 flex gap-1 md:gap-1.5 shrink-0">
						<div class="w-2 h-2 md:w-2.5 md:h-2.5 rounded-full bg-red-500/80"></div>
						<div class="w-2 h-2 md:w-2.5 md:h-2.5 rounded-full bg-yellow-500/80"></div>
						<div class="w-2 h-2 md:w-2.5 md:h-2.5 rounded-full bg-green-500/80"></div>
					</div>
					<div class="text-gray-300 ml-1 md:ml-1 font-bold flex items-center text-xs md:text-base">
						<span class="text-cyan-400 mr-1 md:mr-2 shrink-0">~</span> <span class="text-green-400 mr-1 md:mr-2 shrink-0">❯</span> 
						<div class="logo-typewriter pr-1">
							FAM Desarrollos
						</div>
					</div>
				</a>

				<!-- Language Switcher -->
				<div class="flex items-center gap-1.5 md:gap-3 bg-white/5 border border-white/10 px-2 py-1.5 md:px-4 md:py-2 rounded-lg md:rounded-xl backdrop-blur-md ml-auto">
					<a href="/" class="text-[10px] md:text-sm font-bold text-gray-400 hover:text-white transition-colors">ES</a>
					<span class="text-gray-600 text-[10px] md:text-xs">/</span>
					<span class="text-[10px] md:text-sm font-bold text-cyan-400">EN</span>
				</div>
			</div>
		</nav>

		<!-- Hero Section -->
		<section class="relative w-full min-h-screen flex flex-col items-center justify-center overflow-hidden px-4">
			<div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-600/20 rounded-full blur-[120px] -z-10 mix-blend-screen"></div>
			<div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-blue-600/20 rounded-full blur-[120px] -z-10 mix-blend-screen"></div>
			<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-black/0 via-black to-black -z-20"></div>
			
			<div class="text-center max-w-4xl mx-auto z-10 space-y-8 animate-fade-in-up mt-20">
				
				<h1 class="font-sans text-6xl md:text-8xl font-black tracking-tighter leading-tight text-white">
					We make your next <br/>
					big idea a reality.
				</h1>
				
				<p class="text-xl md:text-2xl text-gray-400 font-light max-w-2xl mx-auto">
					Specialists in SaaS development, custom financial systems, and cutting-edge web experiences.
				</p>
				
				<div class="flex flex-col gap-8 justify-center items-center pt-8 mb-16">
					<div class="flex flex-col sm:flex-row gap-4">
						<a href="#servicios" class="font-sans bg-white text-black px-8 py-4 rounded-full font-bold text-lg hover:bg-gray-200 hover:scale-105 transition-all shadow-[0_0_40px_rgba(255,255,255,0.2)]">
							View Services
						</a>
						<a href="#contacto" class="font-sans relative group bg-white/5 border border-white/10 text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-white/10 hover:border-cyan-500/50 hover:text-cyan-400 hover:scale-105 transition-all backdrop-blur-md overflow-hidden">
							<div class="absolute inset-0 bg-cyan-500/10 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
							<span class="relative z-10">Contact Us</span>
						</a>
					</div>
				</div>
			</div>

			<!-- Interactive Terminal About Us -->
			<TerminalAbout client:load lang="en" />
		</section>

		<!-- Infinite Tech Stack Marquee -->
		<div class="w-full border-y border-white/5 bg-white/[0.02] py-8 overflow-hidden flex whitespace-nowrap">
			<div class="flex animate-marquee gap-16 px-8 items-center text-gray-500 text-xl font-bold tracking-widest">
				<span>NEXT.JS</span> <span>•</span> <span>ASTRO</span> <span>•</span> <span>REACT</span> <span>•</span> <span>SUPABASE</span> <span>•</span> <span>TAILWIND</span> <span>•</span> <span>PYTHON</span> <span>•</span> <span>DJANGO</span> <span>•</span> <span>POSTGRESQL</span> <span>•</span> <span>AWS</span> <span>•</span>
				<span>NEXT.JS</span> <span>•</span> <span>ASTRO</span> <span>•</span> <span>REACT</span> <span>•</span> <span>SUPABASE</span> <span>•</span> <span>TAILWIND</span> <span>•</span> <span>PYTHON</span> <span>•</span> <span>DJANGO</span> <span>•</span> <span>POSTGRESQL</span> <span>•</span> <span>AWS</span>
			</div>
		</div>

		<SolutionsCarousel client:visible lang="en" />

		<!-- Process Section -->
		<div class="bg-[#FAFAFA] border-t border-white/10 pt-16">
			<ProcessSection client:visible lang="en" />
		</div>

		<!-- The Engine Section (Light Theme Breakout) -->
		<section id="arquitectura" class="w-full bg-[#FAFAFA] text-black py-32 border-y border-white/10 relative z-10">
			<div class="max-w-7xl mx-auto px-4">
				<div class="mb-16" data-aos="fade-up">
					<h2 class="text-4xl md:text-5xl font-bold mb-4 text-black">The Engine Behind the Magic</h2>
					<p class="text-gray-600 text-lg max-w-xl">We don't use templates. We build digital ecosystems with the same tech stack and artificial intelligence used by top Silicon Valley companies.</p>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-4 grid-rows-[auto] gap-4 md:gap-6 group">
					
					{/* Card 1: Ecosistema IA */}
					<div data-aos="fade-up" data-aos-delay="100" class="md:col-span-2 bg-white border border-gray-200 rounded-3xl p-8 relative overflow-hidden transition-all duration-300 hover:border-purple-300 hover:shadow-[0_15px_40px_rgba(168,85,247,0.15)] h-[320px] flex flex-col justify-between group/card">
						<div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-transparent to-transparent opacity-0 group-hover/card:opacity-100 transition-opacity duration-700"></div>
						<div class="relative w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center text-purple-600 mb-6 border border-purple-100 shadow-sm">
							<Rocket size={24} class="relative z-10" />
						</div>
						<div class="relative z-10">
							<h3 class="text-2xl font-bold mb-3 tracking-tight text-black">Your Own Software (SaaS)</h3>
							<p class="text-gray-600 leading-relaxed text-sm">Have a brilliant idea? We build tech platforms ready for you to charge subscriptions and offer your own software to thousands of users. Your vision, turned into a scalable business.</p>
						</div>
					</div>

					{/* Card 2: Ecosistema Web */}
					<div data-aos="fade-up" data-aos-delay="200" class="md:col-span-1 bg-white border border-gray-200 rounded-3xl p-8 relative overflow-hidden transition-all duration-300 hover:border-cyan-300 hover:shadow-[0_15px_40px_rgba(6,182,212,0.15)] h-[320px] flex flex-col justify-between group/card">
						<div class="absolute inset-0 bg-gradient-to-br from-cyan-50 via-transparent to-transparent opacity-0 group-hover/card:opacity-100 transition-opacity duration-700"></div>
						<div class="w-12 h-12 bg-cyan-50 rounded-xl flex items-center justify-center text-cyan-600 mb-6 border border-cyan-100 shadow-sm">
							<Zap size={24} />
						</div>
						<div class="relative z-10">
							<h3 class="text-2xl font-bold mb-3 tracking-tight text-black">Instant Performance</h3>
							<p class="text-gray-600 leading-relaxed text-sm">Nobody likes to wait. We optimize every line of code so your website or app loads in the blink of an eye. Provide the best experience and retain clients from the first second.</p>
						</div>
					</div>

					{/* Card 3: Workflows */}
					<div data-aos="fade-up" data-aos-delay="300" class="md:col-span-1 bg-white border border-gray-200 rounded-3xl p-8 relative overflow-hidden transition-all duration-300 hover:border-orange-300 hover:shadow-[0_15px_40px_rgba(249,115,22,0.15)] h-[320px] flex flex-col justify-between group/card">
						<div class="absolute inset-0 bg-gradient-to-br from-orange-50 via-transparent to-transparent opacity-0 group-hover/card:opacity-100 transition-opacity duration-700"></div>
						<div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center text-orange-600 mb-6 border border-orange-100 shadow-sm">
							<Network size={24} class="animate-spin-slow" />
						</div>
						<div class="relative z-10">
							<h3 class="text-2xl font-bold mb-3 tracking-tight text-black">Process Automation</h3>
							<p class="text-gray-600 leading-relaxed text-sm">Make your tools work for you. We connect your systems so repetitive tasks are done automatically without you lifting a finger.</p>
						</div>
					</div>

					{/* Card 4: Infra Cloud */}
					<div data-aos="fade-up" data-aos-delay="100" class="md:col-span-3 bg-white border border-gray-200 rounded-3xl p-8 relative overflow-hidden transition-all duration-300 hover:border-blue-300 hover:shadow-[0_15px_40px_rgba(59,130,246,0.15)] min-h-[220px] flex flex-col justify-center group/card">
						<div class="absolute inset-0 bg-gradient-to-t from-blue-50 via-transparent to-transparent opacity-0 group-hover/card:opacity-100 transition-opacity duration-700"></div>
						<div class="absolute right-10 bottom-0 opacity-[0.03] pointer-events-none translate-x-1/4 translate-y-1/4 animate-float">
							<Database size={200} class="text-blue-900" />
						</div>
						<div class="relative z-10 max-w-2xl">
							<div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600 mb-6 border border-blue-100 shadow-sm">
								<Database size={24} />
							</div>
							<h3 class="text-2xl font-bold mb-3 tracking-tight text-black">Cloud Infrastructure & Security</h3>
							<p class="text-gray-600 leading-relaxed text-sm">Your data protected like a vault, but instantly accessible. We focus on shielding your information in hyper-secure servers, ensuring absolute control a touch away.</p>
						</div>
					</div>

					{/* Card 5: UI/UX */}
					<div data-aos="fade-up" data-aos-delay="300" class="md:col-span-1 bg-white border border-gray-200 rounded-3xl p-8 relative overflow-hidden transition-all duration-300 hover:border-pink-300 hover:shadow-[0_15px_40px_rgba(236,72,153,0.15)] min-h-[220px] flex flex-col justify-center items-center text-center group/card">
						<div class="absolute inset-0 bg-gradient-to-t from-pink-50 via-transparent to-transparent opacity-0 group-hover/card:opacity-100 transition-opacity duration-700"></div>
						<div class="w-12 h-12 bg-pink-50 rounded-full flex items-center justify-center text-pink-600 mb-4 border border-pink-100 shadow-sm group-hover/card:scale-110 transition-transform">
							<Monitor size={24} />
						</div>
						<h3 class="text-xl font-bold tracking-tight text-black">Premium <br/>UI/UX Design</h3>
					</div>

				</div>
			</div>
		</section>

		<!-- Casos de Estudio Section -->
		<section id="proyectos" class="w-full max-w-7xl mx-auto py-32 px-4">
			<div class="mb-16" data-aos="fade-right">
				<h2 class="text-4xl md:text-5xl font-bold mb-4 text-white">Featured Projects</h2>
				<p class="text-gray-400 text-lg max-w-xl">A glimpse into some of the systems and platforms we have built to empower real businesses.</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				
				{/* Project 1 */}
				<div data-aos="zoom-in" data-aos-delay="0" class="group relative bg-white/[0.02] border border-white/5 rounded-3xl p-8 hover:bg-white/[0.04] hover:border-white/20 transition-all duration-300 overflow-hidden flex flex-col justify-center min-h-[280px]">
					<div class="absolute -right-4 -bottom-4 text-[120px] font-black text-white/[0.02] group-hover:text-cyan-500/[0.05] transition-colors duration-500 pointer-events-none select-none">01</div>
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3 group-hover:text-cyan-400 transition-colors">Muni Finanzas</h3>
						<p class="text-gray-400 text-sm leading-relaxed">Comprehensive management system for municipalities. Designed from real internal experience to solve financial control, purchase traceability, and general administration with total transparency.</p>
					</div>
				</div>

				{/* Project 2 */}
				<div data-aos="zoom-in" data-aos-delay="100" class="group relative bg-white/[0.02] border border-white/5 rounded-3xl p-8 hover:bg-white/[0.04] hover:border-white/20 transition-all duration-300 overflow-hidden flex flex-col justify-center min-h-[280px]">
					<div class="absolute -right-4 -bottom-4 text-[120px] font-black text-white/[0.02] group-hover:text-green-500/[0.05] transition-colors duration-500 pointer-events-none select-none">02</div>
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3 group-hover:text-green-400 transition-colors">Citizen Assistant</h3>
						<p class="text-gray-400 text-sm leading-relaxed">Automated WhatsApp module integrated with Muni Finanzas. Resolves frequent citizen queries instantly: waste collection, schedules, appointments, and payments, operating 24/7.</p>
					</div>
				</div>

				{/* Project 3 */}
				<div data-aos="zoom-in" data-aos-delay="200" class="group relative bg-white/[0.02] border border-white/5 rounded-3xl p-8 hover:bg-white/[0.04] hover:border-white/20 transition-all duration-300 overflow-hidden flex flex-col justify-center min-h-[280px]">
					<div class="absolute -right-4 -bottom-4 text-[120px] font-black text-white/[0.02] group-hover:text-purple-500/[0.05] transition-colors duration-500 pointer-events-none select-none">03</div>
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3 group-hover:text-purple-400 transition-colors">Journalism Portal</h3>
						<p class="text-gray-400 text-sm leading-relaxed">High-performance journalistic platform and CMS. An extremely solid editorial system, designed for media outlets, cooperatives, and radios to publish content with an impeccable user experience.</p>
					</div>
				</div>

				{/* Project 4 */}
				<div data-aos="zoom-in" data-aos-delay="0" class="group relative bg-white/[0.02] border border-white/5 rounded-3xl p-8 hover:bg-white/[0.04] hover:border-white/20 transition-all duration-300 overflow-hidden flex flex-col justify-center min-h-[280px]">
					<div class="absolute -right-4 -bottom-4 text-[120px] font-black text-white/[0.02] group-hover:text-yellow-500/[0.05] transition-colors duration-500 pointer-events-none select-none">04</div>
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3 group-hover:text-yellow-400 transition-colors">TuKiosco</h3>
						<p class="text-gray-400 text-sm leading-relaxed">Easy-to-use Point of Sale (POS) system for kiosks and small businesses. Controls cash registers, inventory, clients, and suppliers so intuitively that any merchant understands it in seconds.</p>
					</div>
				</div>

				{/* Project 5 */}
				<div data-aos="zoom-in" data-aos-delay="100" class="group relative bg-white/[0.02] border border-white/5 rounded-3xl p-8 hover:bg-white/[0.04] hover:border-white/20 transition-all duration-300 overflow-hidden flex flex-col justify-center min-h-[280px]">
					<div class="absolute -right-4 -bottom-4 text-[120px] font-black text-white/[0.02] group-hover:text-orange-500/[0.05] transition-colors duration-500 pointer-events-none select-none">05</div>
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3 group-hover:text-orange-400 transition-colors">TallerOS</h3>
						<p class="text-gray-400 text-sm leading-relaxed">Comprehensive digitalization for mechanic workshops. Management of clients, vehicles, quotes, and work orders. Ideal for businesses looking to leave paper behind and professionalize their service.</p>
					</div>
				</div>

				{/* Project 6 */}
				<div data-aos="zoom-in" data-aos-delay="200" class="group relative bg-white/[0.02] border border-white/5 rounded-3xl p-8 hover:bg-white/[0.04] hover:border-white/20 transition-all duration-300 overflow-hidden flex flex-col justify-center min-h-[280px]">
					<div class="absolute -right-4 -bottom-4 text-[120px] font-black text-white/[0.02] group-hover:text-pink-500/[0.05] transition-colors duration-500 pointer-events-none select-none">06</div>
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3 group-hover:text-pink-400 transition-colors">Dolche'B</h3>
						<p class="text-gray-400 text-sm leading-relaxed">More than code, it is a showcase of visual identity and marketing. Web design aggressively focused on conversion, proving that we know how to make a brand capture attention and sell more.</p>
					</div>
				</div>

			</div>
		</section>

		<!-- FAQ Section -->
		<div class="relative w-full border-t border-white/5 bg-gradient-to-b from-[#030303] to-black">
			<FaqSection client:visible lang="en" />
		</div>

		<!-- Contact Section Dual Path -->
		<div data-aos="fade-up">
			<ContactSection client:visible lang="en" />
		</div>

	</main>
</Layout>

<script>
	// Hide on Scroll Logic
	let lastScroll = window.scrollY;
	const nav = document.getElementById('main-nav');
	
	window.addEventListener('scroll', () => {
		const currentScroll = window.scrollY;
		// Solo esconder en mobile (ancho < 768px)
		if (window.innerWidth < 768) {
			if (currentScroll > lastScroll && currentScroll > 100) {
				nav.style.transform = 'translateY(-100%)';
			} else {
				nav.style.transform = 'translateY(0)';
			}
		} else {
			// En desktop siempre visible
			nav.style.transform = 'translateY(0)';
		}
		lastScroll = currentScroll;
	});
</script>

<style is:global>
	/* Custom animations */
	@keyframes marquee {
		0% { transform: translateX(0%); }
		100% { transform: translateX(-50%); }
	}
	.animate-marquee {
		animation: marquee 25s linear infinite;
	}
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	@keyframes typing-logo {
		from { width: 0; }
		to { width: 16ch; }
	}
	@keyframes blink-caret {
		from, to { border-color: transparent; }
		50% { border-color: #22d3ee; }
	}
	.logo-typewriter {
		display: inline-block;
		overflow: hidden;
		white-space: nowrap;
		border-right: 2px solid #22d3ee;
		width: 0;
		animation: typing-logo 1.5s steps(15, end) forwards, blink-caret .75s step-end infinite;
	}
	
	@keyframes pulse-glow {
		0%, 100% { opacity: 0.2; box-shadow: 0 0 5px rgba(168, 85, 247, 0.2); }
		50% { opacity: 1; box-shadow: 0 0 20px rgba(168, 85, 247, 0.8); transform: scale(1.05); }
	}
	.animate-pulse-glow {
		animation: pulse-glow 3s ease-in-out infinite;
	}

	@keyframes float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-15px); }
	}
	.animate-float {
		animation: float 5s ease-in-out infinite;
	}

	@keyframes spin-slow {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}
	.animate-spin-slow {
		animation: spin-slow 10s linear infinite;
	}
</style>
